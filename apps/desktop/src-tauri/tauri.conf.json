{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Video Editor",
  "version": "0.1.0",
  "identifier": "local.ai-video-editor.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm --filter @ai-video-editor/desktop dev",
    "beforeBuildCommand": "corepack pnpm --filter @ai-video-editor/desktop build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Video Editor",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "resources": []
  }
}
