{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-video-editor.local/schemas/command.schema.json",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "enum": [
        "import_media",
        "add_track",
        "delete_track",
        "add_clip",
        "move_clip",
        "trim_clip",
        "split_clip",
        "delete_clip",
        "ripple_delete_clip",
        "apply_color_adjustment",
        "apply_lut",
        "export_timeline"
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "ripple_delete_clip" } } },
      "then": {
        "required": ["clipId", "trackMode"],
        "properties": {
          "clipId": { "type": "string", "minLength": 1 },
          "trackMode": { "enum": ["selected_track", "all_tracks"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "import_media" } } },
      "then": {
        "required": ["paths"],
        "properties": {
          "paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "copyToProject": { "type": "boolean" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "export_timeline" } } },
      "then": {
        "required": ["outputPath", "resolution", "width", "height", "fps", "codec", "container", "quality", "bitrateMbps", "audioEnabled", "colorMode"],
        "properties": {
          "outputPath": { "type": "string", "minLength": 1 },
          "resolution": { "enum": ["source", "custom", "1080p", "1440p", "4k"] },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "fps": { "enum": [24, 25, 30, 50, 60] },
          "codec": { "enum": ["h264_nvenc", "hevc_nvenc", "av1_nvenc"] },
          "container": { "enum": ["mp4", "mkv"] },
          "quality": { "enum": ["trash", "low", "medium", "high", "pro_max"] },
          "bitrateMbps": { "type": "number", "minimum": 1 },
          "audioEnabled": { "type": "boolean" },
          "colorMode": { "enum": ["SDR", "HDR"] }
        }
      }
    }
  ],
  "additionalProperties": true
}
